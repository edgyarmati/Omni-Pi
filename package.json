{
  "name": "omni-pi",
  "version": "0.8.3",
  "description": "Single-agent Pi package that interviews the user, documents the spec, and implements work in bounded slices.",
  "type": "module",
  "license": "MIT",
  "author": "Eduard-David Gyarmati",
  "repository": {
    "type": "git",
    "url": "https://github.com/EdGy2k/Omni-Pi"
  },
  "homepage": "https://github.com/EdGy2k/Omni-Pi#readme",
  "bugs": {
    "url": "https://github.com/EdGy2k/Omni-Pi/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "omni": "bin/omni.js"
  },
  "keywords": [
    "pi-package",
    "pi",
    "agent",
    "planning",
    "implementation",
    "interview"
  ],
  "files": [
    "bin",
    "agents",
    "CHANGELOG.md",
    "extensions",
    "prompts",
    "skills",
    "src",
    "templates",
    "README.md",
    "PROVIDERS.md",
    "CREDITS.md"
  ],
  "scripts": {
    "chat": "node ./bin/omni.js",
    "check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "verify": "npm run check && npm run lint && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pi": {
    "extensions": [
      "./extensions/omni-providers/index.ts",
      "./extensions/omni-core/index.ts",
      "./extensions/omni-memory/index.ts",
      "./node_modules/glimpseui/pi-extension/index.ts",
      "./node_modules/pi-web-access/index.ts",
      "./node_modules/pi-interview/index.ts",
      "./node_modules/@juanibiapina/pi-extension-settings/dist/index.js",
      "./node_modules/@juanibiapina/pi-powerbar/dist"
    ],
    "skills": [
      "./skills",
      "./node_modules/glimpseui/skills",
      "./node_modules/pi-web-access/skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.84",
    "@juanibiapina/pi-extension-settings": "^0.6.0",
    "@juanibiapina/pi-powerbar": "^0.7.1",
    "@mariozechner/pi-coding-agent": "^0.65.2",
    "glimpseui": "^0.6.2",
    "pi-interview": "^0.5.5",
    "pi-web-access": "^0.10.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@mozilla/readability": "0.6.0",
    "brace-expansion": "5.0.5",
    "picomatch": "4.0.4",
    "vite": "7.3.2"
  }
}
